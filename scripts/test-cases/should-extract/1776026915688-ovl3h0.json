    "\u6536\u5230\uff01\u8fd9\u4e2a\u901a\u77e5\u5361\u7247\u786e\u5b9e\u592a\u7b80\u964b\u4e86\u2014\u2014\u7eaf\u6587\u672c\u683c\u5f0f\u3001\u4fe1\u606f\u91cf\u4e0d\u8db3\u3001\u6ca1\u6709\u64cd\u4f5c\u6309\u94ae\u3002\u6211\u5148\u770b\u770b\u90ae\u4ef6\u5361\u7247\u7684\u6837\u5f0f\uff0c\u518d\u627e\u5230 Skill Learner \u53d1\u901a\u77e5\u7684\u5730\u65b9\uff0c\u7ed9\u4f60\u91cd\u65b0\u8bbe\u8ba1\u4e00\u7248\u3002",
